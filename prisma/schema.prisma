// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user") // "user" | "admin"
  country       String?   @default("Unknown")
  avatarUrl     String? // Avaturn 3D avatar GLB URL
  avatarConfig  Json? // Custom in-house avatar configuration
  accounts      Account[]
  sessions      Session[]

  // Security Fields
  passwordChangedAt DateTime? @default(now())
  failedAttempts    Int       @default(0)
  lockUntil         DateTime?
  activeSessionId   String?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model RevokedToken {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id          String   @id @default(cuid())
  ip          String
  email       String?
  count       Int      @default(1)
  lastAttempt DateTime @default(now())

  @@unique([ip, email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id        String   @id @default(cuid())
  email     String
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  objective String
  message   String
  createdAt DateTime @default(now())
}

// ── Client Portal (NYX × brand partners) ───────────────────────────────────
// `BrandPartner` is an approved client granted access to /portal/[slug].
// Naming reflects NYX's existing landing-page language ("Q3 2026 brand partners").

model BrandPartner {
  id         String             @id @default(cuid())
  email      String             @unique
  clientSlug String             @unique
  clientName String
  approvedAt DateTime           @default(now())
  approvedBy String // admin email who approved
  status     BrandPartnerStatus @default(ACTIVE)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  contentPosts  ContentPost[]
  configuration BrandConfiguration?
  viewers       PortalViewer[]
  brandKit      BrandKit?
  chatSessions  ChatSession[]
  monthlySummaries MonthlySummary[]
  notifications    Notification[]

  @@index([email])
  @@index([clientSlug])
  @@index([status])
}

/// Phase 5 follow-up: read-only guests granted access to a brand's
/// /portal/[clientSlug]. Stored as plain emails (not FKs to User) so an
/// admin can grant access to anyone with a Google account; the User row
/// is created on first sign-in by NextAuth's PrismaAdapter.
model PortalViewer {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)
  email          String
  /// Display name shown in the admin list — captured at invite time.
  name           String?
  addedBy        String // admin email
  addedAt        DateTime     @default(now())

  @@unique([brandPartnerId, email])
  @@index([email])
}

// Phase 3 — per-partner content calendar entries
// Phase 4 — added platform, archivedAt, comments back-rel
model ContentPost {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)

  title           String
  scheduledDate   DateTime
  contentType     ContentType
  platform        Platform    @default(INSTAGRAM)
  status          PostStatus  @default(IDEA)
  caption         String      @db.Text
  hashtags        String[]
  visualDirection String      @db.Text
  productionNotes String?     @db.Text
  thumbnailUrl    String?
  mediaUrls       String[]    @default([])

  position Int

  archivedAt DateTime?

  comments PostComment[]
  versions PostVersion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandPartnerId])
  @@index([scheduledDate])
  @@index([status])
  @@index([archivedAt])
}

enum ContentType {
  REEL
  CAROUSEL
  STATIC_POST
  STORY
  REEL_STORY
}

enum PostStatus {
  IDEA
  DRAFTING
  NEEDS_APPROVAL
  NEEDS_REVISION
  APPROVED
  POSTED
}

model PendingPartnerRequest {
  id          String               @id @default(cuid())
  email       String               @unique
  name        String? // captured from Google profile when available
  requestedAt DateTime             @default(now())
  status      PendingPartnerStatus @default(PENDING)
  notes       String? // admin notes during review

  @@index([email])
  @@index([status])
}

enum BrandPartnerStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum PendingPartnerStatus {
  PENDING
  REJECTED
}

// ── Phase 4: brand configuration (lifted from src/lib/portal/brands/*.ts)

model BrandConfiguration {
  id             String       @id @default(cuid())
  brandPartnerId String       @unique
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)

  // Display
  brandName String
  tagline   String?
  logoUrl   String?

  // Theming
  primaryColor   String
  secondaryColor String
  accentColor    String?

  // Social
  instagramHandle String?
  tiktokHandle    String?

  // Client meta (Phase 3 legacy fields preserved for the portal adapter)
  clientContactName String?
  clientPhone       String?
  products          String[] @default([])
  operations        String?

  // Campaign
  packageType   PackageType
  campaignStart DateTime
  campaignEnd   DateTime
  platforms     Platform[]

  // Agency block
  agencyContactName  String?
  agencyContactEmail String?

  // Pack B
  packBEnabled       Boolean  @default(false)
  packBTitle         String?
  packBDescription   String?  @db.Text
  packBSourcePostIds String[] @default([])
  packBSourceLabels  String[] @default([])
  packBGoals         String[] @default([])

  // Footer
  confidentialityNote String? @db.Text
  renewalEmail        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum PackageType {
  TRIAL
  MONTHLY_RETAINER
  CUSTOM
}

enum Platform {
  INSTAGRAM
  TIKTOK
}

// ── Phase 4: post-level comments (revision requests, approval notes,
//    internal admin notes). authorEmail is plain text, not an FK.

model PostComment {
  id          String      @id @default(cuid())
  postId      String
  post        ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorEmail String
  body        String      @db.Text
  type        CommentType
  createdAt   DateTime    @default(now())

  @@index([postId])
  @@index([createdAt])
}

enum CommentType {
  REVISION_REQUEST
  APPROVAL_NOTE
  INTERNAL_ADMIN
}

/// Phase 5 follow-up: snapshot of a ContentPost at a meaningful moment.
/// Today we snapshot on the APPROVED transition so admin edits made
/// after approval don't silently change what the partner agreed to. The
/// snapshot is a JSON blob of the post's content fields at that moment.
model PostVersion {
  id        String      @id @default(cuid())
  postId    String
  post      ContentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  /// Why this snapshot was taken — currently only APPROVED, but the
  /// enum-as-string keeps the door open for future triggers.
  reason    String
  /// Frozen snapshot of the post fields that matter for "what was
  /// approved" — title, scheduledDate, contentType, platform, caption,
  /// hashtags, visualDirection, productionNotes, thumbnailUrl. Stored
  /// as Json so future field additions don't require a migration.
  snapshot  Json
  /// Email of the user who triggered the snapshot (admin or partner).
  snappedBy String
  createdAt DateTime    @default(now())

  @@index([postId])
  @@index([createdAt])
}

// ── Calendar AI: per-brand kit + chat-driven calendar generation ─────────
// A brand kit is the durable bundle of context (logo, palette PDFs,
// product list, tone-of-voice notes, reference images) that the calendar
// chatbot grounds its proposals in. Distinct from BrandConfiguration —
// configuration is what the portal renders, BrandKit is what the AI reads.

model BrandKit {
  id             String       @id @default(cuid())
  brandPartnerId String       @unique
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)

  /// Free-form brand description / tone-of-voice / do-and-dont notes
  /// the admin pastes in chat or types in the kit form. Acts as the
  /// system-prompt seed for every chat turn.
  notes          String?      @db.Text
  /// Audience / persona / positioning blurb.
  audience       String?      @db.Text
  /// "What's working" / past-winners notes — surfaces past successful
  /// post archetypes to the AI for emulation.
  winners        String?      @db.Text

  assets    BrandKitAsset[]
  chunks    EmbeddingChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Any uploaded artefact tied to a brand kit — logo variations, brand
/// guideline PDFs, product photography, mood boards. URL points at
/// Vercel Blob; mime + size kept for client display.
model BrandKitAsset {
  id         String   @id @default(cuid())
  brandKitId String
  brandKit   BrandKit @relation(fields: [brandKitId], references: [id], onDelete: Cascade)

  /// One of: 'logo' | 'guideline' | 'reference' | 'product' | 'other'.
  /// Plain string (not enum) so we can add categories without migrations.
  kind       String
  url        String
  filename   String
  mimeType   String
  sizeBytes  Int
  /// Optional admin caption shown in chat; also embedded for RAG.
  caption    String?  @db.Text

  uploadedBy String
  createdAt  DateTime @default(now())

  @@index([brandKitId])
}

/// Chunked + embedded text from BrandKit notes / asset captions / PDF
/// extractions, used for cosine-similarity retrieval at chat time.
/// embedding stored as Bytes (Float32 little-endian) — cheap and DB-portable.
model EmbeddingChunk {
  id         String   @id @default(cuid())
  brandKitId String
  brandKit   BrandKit @relation(fields: [brandKitId], references: [id], onDelete: Cascade)

  /// Where this chunk came from — used in retrieval UI to cite sources.
  source     String
  /// 1-based index within the source — for stable ordering on re-render.
  chunkIndex Int
  text       String   @db.Text
  /// Float32 vector serialised little-endian. Dim depends on the model
  /// (Gemini text-embedding-004 = 768). We don't enforce dim at the DB
  /// level so the column survives model swaps.
  embedding  Bytes
  /// Model name used to produce the embedding — invalidate retrievals
  /// when model changes.
  model      String

  createdAt DateTime @default(now())

  @@index([brandKitId])
}

/// Per-brand chat session. A session is one conversation thread on the
/// calendar-builder page. Multiple sessions per brand are allowed so an
/// admin can keep "Q3 launch" and "holiday push" separate.
model ChatSession {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)

  /// Free-form session label ("Q3 launch", "BTS week", etc.). Auto-set
  /// from the first user message if blank.
  title          String?

  /// Email of the admin who started the thread.
  createdBy      String

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brandPartnerId])
  @@index([createdBy])
}

/// One message in a chat session. parentId enables the *conversation
/// tree* — edits/retries fork a new branch instead of mutating history,
/// which preserves auditability and lets the UI surface "regenerate".
model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  /// 'user' | 'assistant' | 'system' | 'tool'. String not enum — same
  /// reasoning as BrandKitAsset.kind.
  role      String
  content   String      @db.Text

  /// If the assistant emitted a tool call (e.g. proposeSlots), the
  /// structured payload lands here.
  toolName  String?
  toolArgs  Json?

  /// Parent message id for branching. NULL = root of the thread.
  parentId  String?

  /// Which LLM provider + model produced this (assistant only).
  provider  String?
  model     String?

  /// Token/cost accounting; null for non-assistant turns.
  promptTokens     Int?
  completionTokens Int?

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([parentId])
}

/// Generic prompt cache shared across all LLM calls. key = SHA-256 of
/// (provider + model + prompt + tool-schema-version). value is the raw
/// completion text or JSON. Hit-rate keeps the chat snappy and the
/// Gemini free-tier well under quota.
model LLMCache {
  key       String   @id
  provider  String
  model     String
  /// Stored as text — for tool-call responses, JSON-encoded.
  value     String   @db.Text
  /// Bytes used by the original completion — surfaces eviction wins.
  sizeBytes Int
  /// Hit counter; the LRU eviction job uses this with createdAt.
  hits      Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

model MonthlySummary {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)
  year           Int
  monthIndex     Int
  content        String       @default("")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([brandPartnerId, year, monthIndex])
  @@index([brandPartnerId])
}

model Notification {
  id             String       @id @default(cuid())
  brandPartnerId String
  brandPartner   BrandPartner @relation(fields: [brandPartnerId], references: [id], onDelete: Cascade)
  type           String       // e.g., "NEEDS_APPROVAL", "APPROVED", "REVISION_REQUESTED", "CALENDAR_UPDATED"
  message        String
  postTitle      String?
  postId         String?
  actor          String       // Who triggered the action
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([brandPartnerId])
  @@index([createdAt])
}
